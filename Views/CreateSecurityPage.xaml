<Page x:Class="InvestingManagerApp.Views.CreateSecurityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InvestingManagerApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateSecurityPage"
      Background="#272727"
        FontFamily="Montserrat"
        Foreground="#fff">
    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Margin" Value="0,24px,0,0"/>
        </Style>
        <Style x:Key="MenuIconStyle" TargetType="Image">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="MenuTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="Header1" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,20px"/>
            <Setter Property="FontSize" Value="32px"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#313131"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                    Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1F6FB2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <TextBlock Text="▼"
                           Foreground="White"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="comboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#313131"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderBrush" Value="#A0a0a0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"/>

                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                      Margin="10,0,6,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                      RecognizesAccessKey="True"/>

                                <ToggleButton Grid.Column="1"
                                  Style="{StaticResource DarkComboBoxToggleButton}"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Grid>

                            <Popup x:Name="PART_Popup"
                       Placement="Bottom"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide"
                       IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                Background="#313131"
                                BorderBrush="#A0A0A0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,4,0,0">
                                        <ScrollViewer Margin="4,6,4,6"
                                          SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#3A3A3A"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#1F6FB2"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#808080"/>
                                <Setter TargetName="MainBorder" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="textBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="Background" Value="#313131"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderBrush" Value="#A0a0a0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid Margin="56,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Text="Создать ценную бумагу"
                       Style="{StaticResource Header1}"/>
            <StackPanel Grid.Row="1"
                        Grid.Column="0">
                <TextBlock Text="Название"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Margin="0,0,0,8"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource textBox}"/>
            </StackPanel>
            <StackPanel Grid.Row="1"
            Grid.Column="1">
                <TextBlock Text="Компания"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,8"/>
                <TextBox Text="{Binding Company, UpdateSourceTrigger=PropertyChanged}"
                Style="{StaticResource textBox}"/>
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Grid.Column="2">
                <TextBlock Text="Тикер"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,8"/>
                <TextBox Text="{Binding Ticker, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource textBox}"/>
            </StackPanel>
            <StackPanel Grid.Row="2"
                        Grid.Column="0">
                <TextBlock Text="Тип ценной бумаги"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding SecurityTypes}"
                          SelectedItem="{Binding TheSecurityType}"
                          Style="{StaticResource comboBox}">
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Row="2"
                        Grid.Column="1">        
                <TextBlock Text="Настоящая стоимость"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,8"/>
                <TextBox Text="{Binding CurrentPriceText, UpdateSourceTrigger=PropertyChanged}"
                Style="{StaticResource textBox}"/>
            </StackPanel>
            <TextBlock Grid.Row="3"
               Grid.ColumnSpan="3"
               Text="{Binding ErrorMessage}"
               Foreground="#FF5F5F"
               FontSize="12"
               Margin="0,0,0,12"
               TextWrapping="Wrap"/>
            <Button Grid.Row="4"
                    Grid.Column="0"
                    Width="140"
                    Height="42"
                    Margin="0,24,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Content="Сохранить"
                    Command="{Binding SaveSecurityCommand}"
                    Background="#1F6FB2"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    FontWeight="SemiBold"/>
            <Button Grid.Row="4"
        Grid.Column="1"
        Width="140"
        Height="42"
        Margin="0,24,0,0"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Content="Отмена"
        Command="{Binding CancelCommand}"
        Background="#969696"
        Foreground="White"
        BorderThickness="0"
        FontSize="14"
        FontWeight="SemiBold"/>
        </Grid>
    </Grid>
</Page>
