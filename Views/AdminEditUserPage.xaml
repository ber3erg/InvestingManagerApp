<Page x:Class="InvestingManagerApp.Views.AdminEditUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InvestingManagerApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminEditUserPage"
      Foreground="#FFF"
      FontFamily="Montserrat"
      Background="#272727">
    <Page.Resources>
        <Style x:Key="Header1" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,20px"/>
            <Setter Property="FontSize" Value="32px"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#313131"/>
            <Setter Property="BorderBrush" Value="#8E8E8E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#256EA2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#363636"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid Margin="62,48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Border для различных свойств границ блока -->
            <TextBlock Text="Редактирование пользователя"
                       Grid.Row="0"
                       Grid.ColumnSpan="2"
                       Style="{StaticResource Header1}"/>
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,24,0">
                <TextBlock Text="Имя"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,8"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TextBoxStyle}"/>
            </StackPanel>
            <StackPanel Grid.Row="1"
            Grid.Column="1"
            Margin="0,0,24,0">
                <TextBlock Text="Логин"
                Foreground="White"
                FontSize="14"
                FontWeight="SemiBold"
                Margin="0,0,0,8"/>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
             Style="{StaticResource TextBoxStyle}"/>
            </StackPanel>
            <StackPanel Grid.Row="2"
                        Grid.Column="0"
                        Margin="0,0,24,0">
                <TextBlock Text="Пароль"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,24,0,8"/>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource TextBoxStyle}"/>
            </StackPanel>
            <TextBlock Grid.Row="3"
                       Grid.ColumnSpan="3"
                       Text="{Binding ErrorMessage}"
                       Foreground="#FF5F5F"
                       FontSize="12"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap"/>
            <Button Grid.Row="4"
                    Grid.Column="0"
                    Width="140"
                    Height="42"
                    Margin="0,24,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Content="Сохранить"
                    Command="{Binding SaveChangesCommand}"
                    Background="#1F6FB2"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    FontWeight="SemiBold"/>
            <Button Grid.Row="4"
                    Grid.Column="1"
                    Width="140"
                    Height="42"
                    Margin="0,24,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Content="Отмена"
                    Command="{Binding CanсelChangesCommand}"
                    Background="#969696"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    FontWeight="SemiBold"/>
        </Grid>

    </Grid>
</Page>
